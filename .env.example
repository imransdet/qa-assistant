# =============================================================
# Copy this file to .env and fill in your values.
# cp .env.example .env
# =============================================================


# ─────────────────────────────────────────────────────────────
# ACTIVE PROFILE — fill in one set of credentials below
# To switch profiles: cp .claude/settings.pN.json .claude/settings.json
# ─────────────────────────────────────────────────────────────
JIRA_URL=https://yourcompany.atlassian.net
JIRA_USERNAME=your@email.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_PROJECT=YOUR_PROJECT_KEY

QASE_API_TOKEN=your_qase_api_token_here
QASE_PROJECT=YOUR_QASE_PROJECT_CODE


# ─────────────────────────────────────────────────────────────
# Google Service Account (optional — only needed for Profile 4)
# Required only if you use Google Docs/Sheets as requirements source
# ─────────────────────────────────────────────────────────────
# GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-sa.json
# GOOGLE_DOC_ID=your_google_doc_id_here
# GOOGLE_SA_EMAIL=your-service-account@project.iam.gserviceaccount.com


# ─────────────────────────────────────────────────────────────
# Artifacts — local storage paths (no need to change)
# ─────────────────────────────────────────────────────────────
SCREENSHOT_DIR=./qa-artifacts/screenshots
LOG_DIR=./qa-artifacts/logs
